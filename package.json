{
  "name": "latch",
  "version": "0.2.0",
  "type": "module",
  "bin": {
    "latch": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "pnpm build && node --test tests/*.test.mjs",
    "check": "pnpm typecheck && pnpm test",
    "latch": "pnpm build && node dist/cli.js",
    "skill:link": "bash scripts/link-latch-skill.sh",
    "skill:check": "bash scripts/check-latch-skill.sh"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0"
  },
  "dependencies": {
    "yaml": "^2.9.0"
  }
}
